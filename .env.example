# ClipLoreTV Environment Variables
# Copy to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
PEXELS_API_KEY=your_pexels_api_key
CLIPLORE_API_SECRET=your_random_api_secret_for_cron_auth

# YouTube Shorts (Google Cloud Console -> OAuth 2.0 Client)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Instagram Reels (Meta Developer Portal)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id
